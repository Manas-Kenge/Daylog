[Unit]
Description=Daylog activity tracking server (aw-server-rust)
Documentation=https://github.com/ActivityWatch/aw-server-rust
After=graphical-session.target

[Service]
Type=simple
ExecStart={BIN_DIR}/aw-server-rust --port 5600 --testing false
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
